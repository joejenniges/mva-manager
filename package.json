{
  "name": "mva-manager",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "npm run build:client && tsc",
    "build:server": "tsc",
    "build:client": "cd client && npm install && npm run build",
    "dev": "concurrently -n api,ui -c blue,magenta \"tsx --watch src/index.ts\" \"cd client && npm run dev\"",
    "dev:server": "tsx --watch src/index.ts",
    "dev:client": "cd client && npm run dev",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.44.0",
    "express": "^5.1.0",
    "geocodio-library-node": "^1.13.0",
    "google-auth-library": "^9.0.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
