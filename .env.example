# Server
PORT=3100
NODE_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mva-manager

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=user@gmail.com,other@gmail.com

# Geocodio (geocoding + driving distance)
GEOCODIO_API_KEY=

# Mapbox (address autocomplete)
MAPBOX_TOKEN=
